{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Blank Board",
  "colors": {
    "primary": "#7c6fff",
    "light": "#a594ff",
    "dark": "#5a4fd4"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "introduction",
              "introduction/quickstart",
              "introduction/philosophy"
            ]
          }
        ]
      },
      {
        "tab": "Concepts",
        "groups": [
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/plugin-system",
              "concepts/event-bus",
              "concepts/hooks",
              "concepts/storage"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core",
            "pages": [
              "api/board",
              "api/bus",
              "api/events",
              "api/storage"
            ]
          },
          {
            "group": "Plugin Management",
            "pages": [
              "api/registry",
              "api/containers",
              "api/permissions"
            ]
          },
          {
            "group": "Extensibility",
            "pages": [
              "api/hooks",
              "api/css",
              "api/ui"
            ]
          },
          {
            "group": "Interaction",
            "pages": [
              "api/draggable",
              "api/utils"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Tutorials",
            "pages": [
              "guides/first-plugin",
              "guides/persisting-data",
              "guides/plugin-communication",
              "guides/publishing"
            ]
          }
        ]
      },
      {
        "tab": "Plugins",
        "groups": [
          {
            "group": "Official Plugins",
            "pages": [
              "plugins/sticky-note",
              "plugins/clock",
              "plugins/plugin-manager"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/dheeraz101/Empty",
          "icon": "github"
        },
        {
          "anchor": "Live Demo",
          "href": "https://emptyweb.netlify.app/",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "Community Plugins",
          "href": "https://github.com/dheeraz101/Empty_Plugins",
          "icon": "puzzle-piece"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Live Demo",
      "href": "https://emptyweb.netlify.app/"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dheeraz101/Empty"
    }
